# /Claude/index.html — never cache the entry point
/Claude/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# /Claude/ — same rule for the bare directory path
/Claude/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# JS/CSS chunks have content-hash names — safe to cache forever
/Claude/assets/*
  Cache-Control: public, max-age=31536000, immutable
