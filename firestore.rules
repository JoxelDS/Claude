rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════
    //  SECURITY MODEL
    //  This app uses badge-based auth (no Firebase Auth tokens).
    //  Rules cannot use request.auth for identity. Protection is layered:
    //    1. Document structure validation  — rejects malformed/random writes
    //    2. Field-count caps               — blocks oversized payloads
    //    3. Required-field enforcement     — each collection requires
    //       specific typed fields, stopping arbitrary REST API abuse
    //    4. Immutability on records        — update/delete locked on
    //       submissions, reports, chat messages, archive docs
    //    5. Deny-all catch-all             — blocks all unlisted paths
    //
    //  Reads are intentionally public — inspection records contain no
    //  personal health data and must be accessible across devices.
    // ══════════════════════════════════════════════════════════════════

    // ── Helpers ───────────────────────────────────────────────────────

    // Cap at 80 top-level keys to prevent oversized documents
    function notTooLarge() {
      return request.resource.data.keys().size() <= 80;
    }

    // Field must exist, be a non-empty string, within a max length
    function strField(field, maxLen) {
      return field in request.resource.data
          && request.resource.data[field] is string
          && request.resource.data[field].size() > 0
          && request.resource.data[field].size() <= maxLen;
    }

    // Field must exist and be a boolean
    function boolField(field) {
      return field in request.resource.data
          && request.resource.data[field] is bool;
    }

    // Minimum shape every inspection document must have.
    // Blocks garbage / random REST API writes.
    function validInspection() {
      return notTooLarge()
          && strField("id",             64)
          && strField("inspectorName",  120)
          && strField("siteName",       200)
          && strField("inspectionDate",  32)
          && strField("overallStatus",   32);
    }

    // Minimum shape every user document must have.
    function validUser() {
      return notTooLarge()
          && strField("badgeHash",  128)
          && strField("name",       120)
          && strField("role",        32)
          && boolField("approved");
    }

    // ── Venue Registry ────────────────────────────────────────────────
    // Public read — venue names / addresses are not sensitive.
    // Writes require a structured venue document. Deletes blocked.
    match /venueRegistry/{venueId} {
      allow read: if true;
      allow create: if notTooLarge()
                    && strField("name",    200)
                    && strField("status",   32);
      allow update: if notTooLarge()
                    && strField("name",    200)
                    && strField("status",   32);
      allow delete: if false;
    }

    // ── Analytics aggregates ──────────────────────────────────────────
    match /analyticsAggregates/{docId} {
      allow read: if true;
      allow create, update: if notTooLarge() && strField("venueId", 64);
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    //  LEGACY FLAT COLLECTIONS  (default venue)
    // ══════════════════════════════════════════════════════════════════

    // ── Users (legacy) ────────────────────────────────────────────────
    // Full list must be readable for badge login to find the user.
    // Only the badgeHash (SHA-256) is stored — no raw badge numbers.
    match /users/{userId} {
      allow read:   if true;
      allow create: if validUser();
      allow update: if validUser();
      allow delete: if false;  // Deletions only via admin flow, never arbitrary
    }

    // ── Inspections (legacy) ──────────────────────────────────────────
    match /inspections/{inspectionId} {
      allow read:   if true;
      allow create: if validInspection();
      allow update: if validInspection();
      allow delete: if false;  // Records cannot be deleted from the client
    }

    // ── HACCP Submissions (legacy) ────────────────────────────────────
    match /haccpSubmissions/{submissionId} {
      allow read:   if true;
      allow create: if notTooLarge()
                    && strField("id",           64)
                    && strField("type",         64)
                    && strField("submittedAt",  32);
      allow update: if false;  // Immutable
      allow delete: if false;
    }

    // ── Problem Reports (legacy) ──────────────────────────────────────
    match /problemReports/{reportId} {
      allow read:   if true;
      allow create: if notTooLarge()
                    && strField("id",         64)
                    && strField("reportedAt", 32);
      allow update: if false;  // Immutable
      allow delete: if false;
    }

    // ── Supervisor Chat (legacy) ──────────────────────────────────────
    match /supervisorChat/{messageId} {
      allow read:   if true;
      allow create: if notTooLarge()
                    && strField("id",        64)
                    && strField("sessionId", 64)
                    && strField("sender",    120)
                    && strField("text",      4000)
                    && strField("sentAt",    32);
      allow update: if false;  // Immutable
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    //  VENUE-SCOPED SUBCOLLECTIONS  /venues/{venueId}/...
    // ══════════════════════════════════════════════════════════════════

    match /venues/{venueId} {
      // Venue root doc: read freely, write only with a venueId field
      allow read: if true;
      allow create, update: if notTooLarge() && strField("venueId", 64);
      allow delete: if false;

      // Shared memory (site name autocomplete map)
      match /sharedMemory/{docId} {
        allow read: if true;
        allow create, update: if notTooLarge();
        allow delete: if false;
      }

      // ── Users (venue-scoped) ────────────────────────────────────────
      match /users/{userId} {
        allow read:   if true;
        allow create: if validUser();
        allow update: if validUser();
        allow delete: if false;
      }

      // ── Inspections (venue-scoped) ──────────────────────────────────
      match /inspections/{inspectionId} {
        allow read:   if true;
        allow create: if validInspection();
        allow update: if validInspection();
        allow delete: if false;
      }

      // ── Archive (venue-scoped) ──────────────────────────────────────
      // Write-once; archived records can never be modified or removed
      match /inspections_archive/{inspectionId} {
        allow read:   if true;
        allow create: if validInspection();
        allow update: if false;
        allow delete: if false;
      }

      // ── HACCP Submissions (venue-scoped) ────────────────────────────
      match /haccpSubmissions/{submissionId} {
        allow read:   if true;
        allow create: if notTooLarge()
                      && strField("id",           64)
                      && strField("type",         64)
                      && strField("submittedAt",  32);
        allow update: if false;
        allow delete: if false;
      }

      // ── Problem Reports (venue-scoped) ──────────────────────────────
      match /problemReports/{reportId} {
        allow read:   if true;
        allow create: if notTooLarge()
                      && strField("id",         64)
                      && strField("reportedAt", 32);
        allow update: if false;
        allow delete: if false;
      }

      // ── Supervisor Chat (venue-scoped) ──────────────────────────────
      match /supervisorChat/{messageId} {
        allow read:   if true;
        allow create: if notTooLarge()
                      && strField("id",        64)
                      && strField("sessionId", 64)
                      && strField("sender",    120)
                      && strField("text",      4000)
                      && strField("sentAt",    32);
        allow update: if false;
        allow delete: if false;
      }

      // ── Analytics Aggregates (venue-scoped) ─────────────────────────
      match /analyticsAggregates/{docId} {
        allow read: if true;
        allow create, update: if notTooLarge() && strField("venueId", 64);
        allow delete: if false;
      }
    }

    // ── Deny everything else ──────────────────────────────────────────
    // Any path not explicitly listed above is fully blocked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
